<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Register agent-switchboard:// custom URL protocol for deep link import -->
  <key>CFBundleURLTypes</key>
  <array>
    <dict>
      <key>CFBundleURLName</key>
      <string>Agent Switchboard Deep Link</string>
      <key>CFBundleURLSchemes</key>
      <array>
        <string>agent-switchboard</string>
      </array>
    </dict>
  </array>
</dict>
</plist>

